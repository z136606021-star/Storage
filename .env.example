# Local overrides — generated by scripts/sync-worktree-env.ps1 or scripts/sync-worktree-env.sh (do not commit .env)
#
# Branch registry (SSOT): scripts/worktree-db.ps1 and scripts/worktree-db.sh
# Run sync after checkout or when switching worktree:
#   .\scripts\sync-worktree-env.ps1
#   ./scripts/sync-worktree-env.sh
#   docker compose --env-file .env up -d
#
# main branch example (E:/Storage):
#
# MYSQL_HOST / MINIO_ENDPOINT below use Docker service names (mysql / minio).
# docker-compose.yml and docker-compose-dev.yml inject this file into the
# backend service via env_file. They only override backend container network
# addresses where needed, so backend and MySQL/MinIO talk over Compose network —
# never over localhost. Do not change them to localhost for container use.
#
# When you run the backend OUTSIDE Docker (e.g. IDEA debug, host scripts like
# health-check), sync-worktree-env.ps1/.sh rewrites MYSQL_HOST/MINIO_ENDPOINT
# to localhost + the mapped host port for that profile, since the process is
# then a host process talking to the container's published port.
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DB=storage
MYSQL_USER=storage
MYSQL_PASSWORD=storage123
MYSQL_ROOT_PASSWORD=root123

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=storage

BACKEND_PORT=8080
FRONTEND_PORT=5173
APP_PORT=80
# VITE_API_PROXY only matters for `npm run dev` (local Vite dev server proxy).
# Compose/Nginx deployment (docker compose up -d) does not read this value:
# the built frontend calls relative `/api`, and frontend/nginx.conf reverse
# proxies it to the backend container, so no CORS/base-URL rebuild is needed.
VITE_API_PROXY=http://localhost:8080
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SECURE=false
RESET_ADMIN_PASSWORD_ON_STARTUP=true
JWT_SECRET=dev-only-change-this-jwt-secret-at-least-32-bytes
JWT_TTL_MINUTES=120
UPLOAD_MAX_SIZE_BYTES=5368709120
UPLOAD_MAX_REQUEST_SIZE_BYTES=5505025024
UPLOAD_MAX_FILES_PER_RECORD=20

# Password reset mail. Gmail direct SMTP defaults are smtp.gmail.com:587 with STARTTLS.
# Use a Google app password for MAIL_PASSWORD; never commit a real mailbox password.
# APP_PUBLIC_BASE_URL must be the URL end users actually open in a browser
# (Nginx entry point, e.g. http://localhost or a real domain in production),
# not an internal container address — it is only used to build the reset link.
# docker-compose-dev.yml overrides the backend value to
# http://localhost:${FRONTEND_PORT} for dev profile.
APP_PUBLIC_BASE_URL=http://localhost
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
PASSWORD_VERIFICATION_CODE_LENGTH=6
PASSWORD_VERIFICATION_TTL_MINUTES=10
PASSWORD_VERIFICATION_SEND_COOLDOWN_SECONDS=60
PASSWORD_VERIFICATION_MAX_VERIFY_FAILURES=5
PASSWORD_VERIFICATION_VERIFY_FAILURE_WINDOW_MINUTES=15
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true

# sync-worktree-env.ps1 / sync-worktree-env.sh preserves existing credentials, app ports, API proxy, JWT, upload, and mail values when regenerating .env.

COMPOSE_PROJECT_NAME=storage-main
STORAGE_MYSQL_PORT=3307
STORAGE_MINIO_PORT=9000
STORAGE_MYSQL_CONTAINER=storage-main-mysql
STORAGE_MINIO_CONTAINER=storage-main-minio
STORAGE_MYSQL_VOLUME=storage-main_mysql_data
STORAGE_MINIO_VOLUME=storage-main_minio_data
