# MySQL connection (copy to .env for local overrides; do not commit .env)
#
# Git worktree 默认使用本目录 docker compose（端口 3307），
# 勿与主仓库 Storage 的 3306 MySQL 混用。
MYSQL_HOST=localhost
MYSQL_PORT=3307
MYSQL_DB=storage
MYSQL_USER=storage
MYSQL_PASSWORD=storage123

# MinIO object storage
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=storage
