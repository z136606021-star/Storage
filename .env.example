# Local overrides — generated by scripts/sync-worktree-env.ps1 or scripts/sync-worktree-env.sh (do not commit .env)
#
# Fixed Compose infrastructure (project name, container names, MySQL/MinIO host ports) lives in
# docker-compose.yml / docker-compose-dev.yml — not in .env.
#
# === Local dev (docker-compose-dev.yml) ===
# Run sync after checkout:
#   .\scripts\sync-worktree-env.ps1
#   ./scripts/sync-worktree-env.sh
#   docker compose --env-file .env -f docker-compose.yml -f docker-compose-dev.yml up -d
#
# Local dev Compose hardcodes: MySQL 3307, MinIO 9000/9001, containers storage-mysql / storage-minio / storage-backend / storage-frontend.
# Inside dev Compose network, backend talks to mysql:3306 and http://minio:9000 (overridden in docker-compose-dev.yml).
# When running backend OUTSIDE Docker (IDEA debug), use MYSQL_HOST=127.0.0.1, MYSQL_PORT=3307, MINIO_ENDPOINT=http://127.0.0.1:9000.
#
# === Production (docker-compose.yml only) ===
# Do NOT run sync-worktree-env for prod. Maintain .env manually from this template.
# Production deploys backend + frontend only; connect to existing MySQL and MinIO:
#   MYSQL_HOST=mysql.internal.example
#   MYSQL_PORT=3306
#   MINIO_ENDPOINT=https://minio.internal.example
# Endpoints must be reachable from the backend container network.
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_DB=storage
MYSQL_USER=storage
MYSQL_PASSWORD=storage123
MYSQL_ROOT_PASSWORD=root123

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET=storage

BACKEND_PORT=8080
FRONTEND_PORT=5173
APP_PORT=80
# VITE_API_PROXY only matters for `npm run dev` (local Vite dev server proxy).
# Compose/Nginx deployment (docker compose up -d) does not read this value:
# the built frontend calls relative `/api`, and frontend/nginx.conf reverse
# proxies it to the backend container, so no CORS/base-URL rebuild is needed.
VITE_API_PROXY=http://localhost:8080
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SECURE=false
RESET_ADMIN_PASSWORD_ON_STARTUP=true
JWT_SECRET=dev-only-change-this-jwt-secret-at-least-32-bytes
JWT_TTL_MINUTES=120
# Single upload limit: max HTTP request body size for one file per request.
# Drives Spring multipart, upload-policy, and Nginx client_max_body_size (via container env at start).
# Multipart boundaries/metadata consume a small overhead; actual file bytes will be slightly below this value.
# Change .env and restart backend + frontend containers; no manual nginx.conf edit or image rebuild required.
UPLOAD_MAX_REQUEST_SIZE_BYTES=5505025024

# SMTP supports authenticated Gmail or an anonymous internal relay. Gmail defaults to smtp.gmail.com:587 with STARTTLS;
# use a Google app password for MAIL_PASSWORD and never commit a real mailbox password.
# Anonymous internal relay example (no credentials):
# MAIL_HOST=corimc04.corp.jabil.org
# MAIL_PORT=25
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_SMTP_AUTH=false
# MAIL_SMTP_STARTTLS_ENABLE=false
# MAIL_FROM=HUA Machining Center<HMC@Jabil.com>
# APP_PUBLIC_BASE_URL must be the URL end users actually open in a browser
# (Nginx entry point, e.g. http://localhost or a real domain in production),
# not an internal container address — it is only used to build the reset link.
# docker-compose-dev.yml overrides the backend value to
# http://localhost:${FRONTEND_PORT} for dev profile.
APP_PUBLIC_BASE_URL=http://localhost
PASSWORD_RESET_TOKEN_TTL_MINUTES=30
PASSWORD_VERIFICATION_CODE_LENGTH=6
PASSWORD_VERIFICATION_TTL_MINUTES=10
PASSWORD_VERIFICATION_SEND_COOLDOWN_SECONDS=60
PASSWORD_VERIFICATION_MAX_VERIFY_FAILURES=5
PASSWORD_VERIFICATION_VERIFY_FAILURE_WINDOW_MINUTES=15
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLE=true

# Exception log retention and field limits (backend only).
EXCEPTION_LOG_RETENTION_DAYS=30
EXCEPTION_LOG_MAX_STACK_TRACE_LENGTH=8000
EXCEPTION_LOG_MAX_SUMMARY_LENGTH=500

# sync-worktree-env.ps1 / sync-worktree-env.sh preserves existing credentials, app ports, API proxy, JWT, upload, and mail values when regenerating .env.
